# Supabase — Dashboard: Project Settings → API (or Data API)
#
# URL: use "Project URL" — https://YOUR_PROJECT_REF.supabase.co (not the dashboard URL)
#
# Keys: Publishable = client + Express JWT verify. Secret / service_role = server ONLY (never VITE_*).
# Copy this file to .env and fill in real values. Do not commit .env.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-or-legacy-anon-key

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-publishable-or-legacy-anon-key

VITE_MOCK_MODE=false
API_MOCK_MODE=false

# Required for database-backed auth + API (service role bypasses RLS for the Express server).
SUPABASE_SERVICE_ROLE_KEY=your-secret-or-service-role-key

# Sign JWTs issued by /api/auth/login (use a long random string in production).
APP_JWT_SECRET=change-this-to-a-long-random-string

# Optional: comma-separated emails that register as approved admin (same as first-user bootstrap).
# ADMIN_BOOTSTRAP_EMAILS=teacher@school.edu,you@example.com

# Forgot-password API: when not 'false', JSON includes resetPath / resetToken (class demo). Set to false in production.
# APP_EXPOSE_PASSWORD_RESET_LINK=true

PORT=3001

# Optional: listings/violations with no seller default to this seller_email (defaults to seller@cpsc.demo).
# Set to none to disable auto-assignment in environments with real sellers.
# DEFAULT_VIOLATION_SELLER_EMAIL=seller@cpsc.demo

# Optional: this login can open any violation and submit seller responses (demo training). Default seller@cpsc.demo.
# DEMO_SELLER_FULL_ACCESS_EMAIL=seller@cpsc.demo

# CLIENT_ORIGIN=https://your-app.up.railway.app,http://localhost:5173

# Optional: separate Supabase project for login/session audit (see scripts/personal/login_audit_schema.sql).
# AUDIT_SUPABASE_URL=https://your-audit-project.supabase.co
# AUDIT_SUPABASE_SERVICE_ROLE_KEY=your-audit-service-role-key

# Optional: HMAC salt for fingerprint_hash column in audit DB (omit to store null fingerprint).
# LOGIN_AUDIT_SALT=long-random-string

# Optional: enable automatic CPSC API import every Monday at 9:00 AM America/New_York
# (imports previous week Monday-Sunday by recall_date window).
# CPSC_WEEKLY_IMPORT_ENABLED=false
